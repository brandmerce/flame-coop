{
  "name": "flame-coop",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @opennextjs/cloudflare build && sh -c 'cp -r .open-next/cloudflare .open-next/middleware .open-next/server-functions .open-next/assets/ 2>/dev/null; cp -r .open-next/.build .open-next/assets/ 2>/dev/null; cp .open-next/worker.js .open-next/assets/_worker.js'",
    "pages:deploy": "wrangler deploy",
    "pages:dev": "wrangler dev"
  },
  "dependencies": {
    "@keystatic/core": "^0.5.0",
    "@keystatic/next": "^5.0.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.22.0",
    "next": "^15.5.15",
    "next-sanity": "^12.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanity": "^5.24.0",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vercel": "^34.0.0",
    "wrangler": "^3.0.0"
  }
